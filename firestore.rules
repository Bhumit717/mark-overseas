rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAllowedDomain() {
      // 🌐 Standard Production & Trusted Test Domains
      return request.resource.data.authorizedDomain.matches('^https://(www\\.)?mark-overseas\\.com$') || 
             request.resource.data.authorizedDomain.matches('^https://(www\\.)?mark-overseas\\.vercel\\.app$') ||
             request.resource.data.authorizedDomain.matches('^http://localhost:.*$') || 
             request.resource.data.authorizedDomain.matches('^http://127\\.0\\.0\\.1:.*$');
    }

    function correctPassword(pwd) {
      // 🔑 The Master Key for the Admin
      return pwd == 'Mark_Vault'; 
    }

    match /inquiry_vault/{pwd}/data/{id} {
      // ✅ CREATE → PUBLIC IF THROUGH FORM
      allow create: if isAllowedDomain();

      // ✅ ADMIN READ / DELETE → ONLY AUTHORIZED EMAIL
      allow read, delete: if request.auth != null && request.auth.token.email == 'markoverseas28@gmail.com';
    }



    match /{document=**} {
      allow read, write: if false;
    }
  }
}
