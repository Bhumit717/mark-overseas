rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // inquiry_vault/Mark_Vault/data/{id}
    match /inquiry_vault/{vaultId}/data/{id} {
      // ✅ CREATE → Server-side Admin SDK always bypasses rules.
      //    For client-side fallback writes, only allow if authenticated admin.
      allow create: if request.auth != null && 
                       (request.auth.token.email == 'markoverseas28@gmail.com' || 
                        request.auth.token.email == 'bhumitnasit1@gmail.com');

      // ✅ READ & DELETE → Only authorized admin emails
      allow read, delete, update: if request.auth != null && 
                       (request.auth.token.email == 'markoverseas28@gmail.com' || 
                        request.auth.token.email == 'bhumitnasit1@gmail.com');
    }

    // Block all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
